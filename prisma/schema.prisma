generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Form {
  id    Int    @id @default(autoincrement())
  name  String
  email String
}

model Onboarding {
  id               String   @id @default(uuid())
  userId           String   @unique
  companyName      String
  businessType     String
  role             String
  phoneNumber      String
  pincode          String
  gstin            String
  interestedMetals String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  mcxPriceAlerts MCXPriceAlert[]
  lmePriceAlerts LMEPriceAlert[]
}

model FuturesPrice {
  id                String   @id @default(uuid())
  date              DateTime
  timestamp         DateTime
  contractMonth     String
  price             Float
  rateChange        Float
  rateChangePercent Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, contractMonth])
  @@index([date])
  @@index([contractMonth])
}


model AluminumSnapshot {
  id               String   @id @default(uuid())
  timestamp        DateTime

  month1Label      String
  month1Price      Decimal  @db.Decimal(10, 2)
  month1RateVal    Decimal  @db.Decimal(10, 2)
  month1RatePct    Decimal  @db.Decimal(6, 2)

  month2Label      String
  month2Price      Decimal  @db.Decimal(10, 2)
  month2RateVal    Decimal  @db.Decimal(10, 2)
  month2RatePct    Decimal  @db.Decimal(6, 2)

  month3Label      String
  month3Price      Decimal  @db.Decimal(10, 2)
  month3RateVal    Decimal  @db.Decimal(10, 2)
  month3RatePct    Decimal  @db.Decimal(6, 2)

  createdAt        DateTime @default(now())

  @@index([timestamp])
}

model MetalPrice {
  id            String   @id @default(uuid())
  metal         String   // e.g., "aluminum", "copper"
  spotPrice     Decimal  @db.Decimal(10, 2)
  change        Decimal  @db.Decimal(10, 2)
  changePercent Decimal  @db.Decimal(6, 2)
  lastUpdated   DateTime
  createdAt     DateTime @default(now())

  @@index([metal])
  @@index([lastUpdated])
}

// Price Alert models

enum AlertType {
  PRICE
  PERCENTAGE
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
  EXPIRED
  CANCELLED
}

enum NotificationMethod {
  WEB
  WHATSAPP
  EMAIL
}

enum PercentageType {
  GAIN
  LOSS
  GAINLOSS
}

model MCXPriceAlert {
  id                String            @id @default(uuid())
  userId            Int               // User ID as foreign key
  user              User              @relation(fields: [userId], references: [id])  // Relation to User model
  currentPrice      Decimal           @db.Decimal(10, 2) // Current price (updated with live data)
  targetPrice       Decimal?          @db.Decimal(10, 2) // For price-based alerts
  alertType         AlertType         @default(PRICE)
  percentageType    PercentageType?   // Only for percentage-based alerts
  targetPercentage  Decimal?          @db.Decimal(6, 2)  // Only for percentage-based alerts
  calculatedTarget  Decimal?          @db.Decimal(10, 2) // Stores the calculated target price for percentage alerts
  status            AlertStatus       @default(ACTIVE)
  notificationMethod NotificationMethod
  customMessage     String?           // Optional custom message
  lastUpdated       DateTime          @default(now())    // Timestamp of last price update
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  expiresAt         DateTime?         // Optional expiration date

  @@index([userId])
  @@index([status])
}

model LMEPriceAlert {
  id                String            @id @default(uuid())
  userId            Int               // User ID as foreign key
  user              User              @relation(fields: [userId], references: [id])  // Relation to User model
  currentPrice      Decimal           @db.Decimal(10, 2) // Current price (updated with live data)
  targetPrice       Decimal?          @db.Decimal(10, 2) // For price-based alerts
  alertType         AlertType         @default(PRICE)
  percentageType    PercentageType?   // Only for percentage-based alerts
  targetPercentage  Decimal?          @db.Decimal(6, 2)  // Only for percentage-based alerts
  calculatedTarget  Decimal?          @db.Decimal(10, 2) // Stores the calculated target price for percentage alerts
  status            AlertStatus       @default(ACTIVE)
  notificationMethod NotificationMethod
  customMessage     String?           // Optional custom message
  lastUpdated       DateTime          @default(now())    // Timestamp of last price update
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  expiresAt         DateTime?         // Optional expiration date

  @@index([userId])
  @@index([status])
}

model LME_3_MetalPrice {
  id           Int      @id @default(autoincrement())
  rateOfChange String
  percentage   Float
  timeSpan     String
  timestamp    DateTime
  value        Float
  createdAt    DateTime @default(now())
}

model SBITTRate {
  id           String   @id @default(uuid())
  sbiTTSell    Decimal  @db.Decimal(10, 4)
  sbiTTBuy     Decimal? @db.Decimal(10, 4)
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([timestamp])
}

